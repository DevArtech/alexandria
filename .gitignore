# Rust / Cargo
/target/

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp
*~

# Environment / secrets
.env
.env.*

# Alexandria — repo-root library created during development / CI
/.alexandria/
/my-library/
/library/
**/node_modules/

# Rebuildable index cache anywhere in the tree (plain-text store is source of truth)
**/.alexandria/index.db
**/.alexandria/fast_reflections/
**/.alexandria/config.toml
**/.alexandria/meta_log/

# Optional: ignore any SQLite DB outside .alexandria (belt-and-suspenders)
**/*.db

# Local embedding model caches (M2+ providers)
.fastembed_cache/
